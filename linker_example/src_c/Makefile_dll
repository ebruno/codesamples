# -*- mode: makefile -*-
DESTDIR = .

LIB_NAME  = swtrstrlib

LIB_ALL_IN_ONE = all_in_one

SRC_FILES = lremove_char.c \
	    remove_char.c \
	    rremove_char.c

ALL_IN_ONES_SRC = all_in_one.c

OBJ_FILES = lremove_char.o \
	    remove_char.o \
	    rremove_char.o

DEMOS_SRC = main.c

DEMO_MAIN_OBJ  = main.o

ALL_IN_ONE_OBJ = all_in_one.o

DEMO_ALL_IN_ONE = demo_allinone_dll

DEMO_SEPARATE   = demo_separate_dll

PICFLAGS = -fPIC # Position-Independent Code for shared libraries

LDFLAGS = -shared # Linker flag to create a shared library

CC = gcc

all: dynamic dynamic_all_in_one demo_one demo_two display_sizes

dynamic: lib$(LIB_NAME).so

dynamic_all_in_one: lib$(LIB_ALL_IN_ONE).so

lib$(LIB_NAME).so: $(OBJ_FILES)
	@$(CC) $(LDFLAGS) -o $@ $^

lib$(LIB_ALL_IN_ONE).so: $(ALL_IN_ONE_OBJ)
	@$(CC) $(LDFLAGS) -o $@ $^


demo_one: $(DEMO_MAIN_OBJ)
	@gcc -Wl,-Map=$(DEMO_SEPARATE).map -o $(DEMO_SEPARATE) $(DEMO_MAIN_OBJ) -L$(CURDIR) -l$(LIB_NAME) -Wl,-rpath=$(CURDIR);

demo_two:
	@gcc -Wl,-Map=$(DEMO_ALL_IN_ONE).map -o $(DEMO_ALL_IN_ONE) $(DEMO_MAIN_OBJ) -L$(CURDIR) -l$(LIB_ALL_IN_ONE) -Wl,-rpath=$(CURDIR);

display_sizes:
	@echo "Note with a dll/shared library there is no size difference."
	@ls -l  $(DEMO_SEPARATE) $(DEMO_ALL_IN_ONE)


# Rule to compile C source files into object files
%.o: %.c
	$(CC) $(CFLAGS) $(PICFLAGS) -c $< -o $@
# Clean up generated files
clean:
	@$(RM) $(OBJ_FILES) $(DEMO_MAIN_OBJ) $(ALL_IN_ONE_OBJ) lib$(LIB_NAME).so lib$(LIB_ALL_IN_ONE).so;
	@$(RM) $(DEMO_SEPARATE) $(DEMO_ALL_IN_ONE);
	@$(RM) *.map;
	@$(RM) *~;
	@$(RM) #*#;

dist-clean: clean
	  @$(MAKE) -f Makefile_sections clean;
	  @$(MAKE) -f Makefile clean;
